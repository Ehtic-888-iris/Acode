<script>
    // 🌌 3D ARIS ENGINE
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    document.getElementById('canvas-container').appendChild(renderer.domElement);

    const geo = new THREE.IcosahedronGeometry(25, 2);
    const mat = new THREE.MeshBasicMaterial({ color: 0xFFD700, wireframe: true, transparent: true, opacity: 0.05 });
    const globe = new THREE.Mesh(geo, mat);
    scene.add(globe);
    camera.position.z = 50;

    function animate3D() {
        requestAnimationFrame(animate3D);
        globe.rotation.y += 0.001;
        globe.rotation.x += 0.0005;
        renderer.render(scene, camera);
    }
    animate3D();

    // 🕒 DIGITAL TIME SYSTEM
    function updateClock() {
        document.getElementById('digital-clock').innerText = new Date().toLocaleTimeString('en-GB', { hour12: false });
    }
    setInterval(updateClock, 1000);
    updateClock();

    // 📡 24 NODES GENERATOR
    const nodes = document.getElementById('station-nodes');
    for(let i=1; i<=24; i++) {
        const d = document.createElement('div');
        d.className = `h-10 border border-yellow-900/50 flex items-center justify-center text-[9px] font-bold ${i <= 7 ? 'bg-green-500/10 border-green-500 text-green-500' : 'text-yellow-900'}`;
        d.innerText = String(i).padStart(2, '0');
        nodes.appendChild(d);
    }

    // 📈 DYNAMIC CHART SIMULATOR
    const chart = document.getElementById('chart-area');
    for(let i=0; i<50; i++) {
        const bar = document.createElement('div');
        const h = Math.random() * 70 + 20;
        bar.className = `flex-1 ${Math.random() > 0.4 ? 'bg-[#00c853]' : 'bg-[#ff1744]'} opacity-80`;
        bar.style.height = h + '%';
        chart.appendChild(bar);
    }
</script>
